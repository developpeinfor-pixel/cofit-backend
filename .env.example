# Server
PORT=3000
# Comma-separated list. Leave empty to allow all origins in development.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081,http://localhost:8091,http://localhost:8092

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cofit

# Auth
JWT_SECRET=change_me_to_a_long_random_secret
TICKET_QR_SECRET=change_me_to_another_long_random_secret
JWT_EXPIRES_IN=30d
ADMIN_JWT_EXPIRES_IN=8h

# Optional bootstrap super-admin (created on startup if not existing)
SUPER_ADMIN_EMAIL=superadmin@cofit.app
SUPER_ADMIN_PASSWORD=SuperAdmin123!
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin
SUPER_ADMIN_PHONE=+10000000000
